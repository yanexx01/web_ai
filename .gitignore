```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
vendor/
composer.lock
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/

# Coverage
.coverage
coverage/
htmlcov/

# OS generated files
.DS_Store
Thumbs.db

# Cache directories
.cache/
.mypy_cache/
.pytest_cache/
.coverage*
.nyc_output/
```