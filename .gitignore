# Laravel-specific ignores
vendor/
composer.lock
.env
.env.*
!.env.example

# Compiled and build artifacts
*.php~
*.pyc
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build and distribution
dist/
build/
target/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment specific
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db

# Cache directories
.cache/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/

# Testing
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp
